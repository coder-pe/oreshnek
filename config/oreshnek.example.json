{
  "host": "0.0.0.0",
  "port": 8080,
  "thread_pool_size": 8,
  "max_connections": 1000,

  "upload_dir": "./uploads/",
  "static_dir": "./static/",
  "max_file_size": 524288000,

  "_comment_secret": "Prefer the ORESHNEK_JWT_SECRET environment variable over committing this.",
  "jwt_secret": "change-me-in-production",
  "jwt_expire_hours": 24,

  "read_timeout_sec": 30,
  "write_timeout_sec": 30,
  "idle_timeout_sec": 60,
  "shutdown_grace_sec": 10,
  "handler_timeout_sec": 30,

  "log_level": "info",
  "log_file": "",
  "log_max_bytes": 10485760,
  "log_max_files": 5,

  "db": {
    "backend": "sqlite",
    "sqlite": {
      "path": "./database.db",
      "pool_size": 4,
      "busy_timeout_ms": 5000
    },
    "postgres": {
      "_comment": "Prefer ORESHNEK_PG_PASSWORD / ORESHNEK_DATABASE_URL for secrets.",
      "host": "127.0.0.1",
      "port": 5432,
      "dbname": "oreshnek",
      "user": "oreshnek",
      "password": "",
      "sslmode": "prefer",
      "pool_size": 8,
      "connect_timeout_sec": 5
    }
  },

  "tls": {
    "_comment": "When enabled the listen port speaks HTTPS. Prefer ORESHNEK_TLS_CERT / ORESHNEK_TLS_KEY for paths.",
    "enabled": false,
    "cert_file": "",
    "key_file": "",
    "min_version": "1.2"
  },

  "rate_limit": {
    "_comment": "Per-IP token bucket (on by default). sustained requests_per_second with a peak of burst; set enabled=false to disable.",
    "enabled": true,
    "requests_per_second": 50,
    "burst": 100
  },

  "metrics": {
    "_comment": "Prometheus text-format metrics exposed at the given GET path.",
    "enabled": false,
    "path": "/metrics"
  },

  "cors_enabled": false,
  "cors_allow_origin": "*"
}
